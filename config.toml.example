# cee-exporter configuration example
# Copy to config.toml and adjust for your environment.
#
# Environment variable overrides:
#   CEE_LOG_LEVEL   — debug | info | warn | error
#   CEE_LOG_FORMAT  — json | text

# Hostname embedded in every generated event.
# Defaults to os.Hostname() if not set.
# Tip: set this to the PowerStore NAS hostname for easier correlation.
# hostname = "powerstore-nas01"

# ─────────────────────────────────────────────────────────────────────────────
# HTTP listener
# ─────────────────────────────────────────────────────────────────────────────
[listen]
addr      = "0.0.0.0:12228"
tls       = false
# cert_file = "/etc/cee-exporter/tls/server.crt"
# key_file  = "/etc/cee-exporter/tls/server.key"

# ─────────────────────────────────────────────────────────────────────────────
# Output backend
#
# type = "gelf"   → GELF JSON over UDP/TCP to Graylog (recommended for Linux)
# type = "evtx"   → Binary .evtx file (Windows: Win32 API; Linux: stub in v1)
# type = "multi"  → Fan-out to multiple backends simultaneously
# ─────────────────────────────────────────────────────────────────────────────
[output]
type = "gelf"

# GELF output (Graylog)
gelf_host     = "graylog.corp.local"
gelf_port     = 12201
gelf_protocol = "udp"   # or "tcp"
gelf_tls      = false   # only applies when gelf_protocol = "tcp"

# EVTX output path (Linux stub / future BinaryEvtxWriter)
# evtx_path = "/var/log/cee-exporter"

# Multi-target example (fan-out to both GELF and EVTX)
# type    = "multi"
# targets = ["gelf", "evtx"]

# ─────────────────────────────────────────────────────────────────────────────
# Async queue
# ─────────────────────────────────────────────────────────────────────────────
[queue]
capacity = 100000  # max events buffered before dropping
workers  = 4       # concurrent writer goroutines

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
[logging]
level  = "info"  # debug | info | warn | error
format = "json"  # json (production) | text (development)

# ─────────────────────────────────────────────────────────────────────────────
# Prometheus /metrics endpoint
# Scrape with: curl http://HOST:9228/metrics
# Default port 9228 is separate from the CEPA listener port 12228.
# ─────────────────────────────────────────────────────────────────────────────
[metrics]
enabled = true
addr    = "0.0.0.0:9228"
